{% comment %}
  Jolly Ticket Form - Modulo apertura segnalazioni tecniche
{% endcomment %}

<div class="max-w-4xl mx-auto py-12 px-4 sm:px-6 lg:px-8 text-primary font-sans">
  
  <div class="bg-white p-10 md:p-16 rounded-[48px] border border-outline-variant/20 shadow-2xl space-y-10">
    <div class="text-center space-y-4">
      <h1 class="text-4xl font-black uppercase italic tracking-tighter">Apri Segnalazione</h1>
      <p class="text-outline text-sm font-bold uppercase tracking-[0.2em]">Il tuo supporto tecnico Jolly Care</p>
    </div>

    <!-- MESSAGGIO DINAMICO PIANO -->
    <div id="ticket-plan-alert" class="p-6 rounded-3xl bg-surface-container-low border border-outline-variant/20 text-sm font-medium flex items-center gap-4 italic">
      <span class="material-symbols-outlined text-primary">info</span>
      <span id="alert-text">Verifica abbonamento in corso...</span>
    </div>

    <form id="jolly-ticket-form" class="space-y-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="space-y-3">
          <label class="block text-[10px] font-black text-primary uppercase tracking-widest">Tipo di Problematica</label>
          <select id="ticket-type" required class="w-full px-6 py-4 rounded-2xl bg-surface-container-low border border-outline-variant focus:bg-white focus:border-primary font-bold h-[65px] outline-none transition-all">
            <option value="Guasto Pompa">Guasto Pompa / Filtrazione</option>
            <option value="Acqua Verde">Analisi / Acqua Verde</option>
            <option value="Perdita">Sospetta Perdita</option>
            <option value="Accessori">Robot / Accessori</option>
            <option value="Altro">Altro (Specifica in descrizione)</option>
          </select>
        </div>
        <div class="space-y-3">
          <label class="block text-[10px] font-black text-primary uppercase tracking-widest">Priorità</label>
          <div id="priority-badge" class="h-[65px] flex items-center px-8 rounded-2xl bg-surface-container-low text-primary font-black uppercase italic text-xs tracking-widest border border-outline-variant opacity-50">
            Standard (Membro Base)
          </div>
        </div>
      </div>

      <div class="space-y-3">
        <label class="block text-[10px] font-black text-primary uppercase tracking-widest">Descrizione del Problema</label>
        <textarea id="ticket-desc" required rows="5" placeholder="Descrivi il guasto o l'esigenza..." class="w-full px-6 py-5 rounded-3xl bg-surface-container-low border border-outline-variant focus:bg-white focus:border-primary font-medium outline-none transition-all"></textarea>
      </div>

      <button type="submit" id="submit-btn" class="w-full bg-primary text-white py-6 rounded-3xl font-black text-xs uppercase tracking-[0.3em] shadow-xl hover:brightness-110 hover:scale-[1.02] transition-all">
        Invia Segnalazione
      </button>
    </form>

    <div id="success-msg" class="hidden text-center space-y-6 py-10 animate-in fade-in zoom-in duration-500">
      <span class="material-symbols-outlined text-emerald-600 text-8xl">check_circle</span>
      <h2 class="text-3xl font-black uppercase italic tracking-tighter text-primary">Segnalazione Inviata</h2>
      <p class="text-outline font-medium">I nostri tecnici sono stati avvisati. Riceverai un aggiornamento via email o WhatsApp.</p>
      <a href="/pages/club" class="inline-block text-primary font-black text-[10px] uppercase tracking-widest border-b-2 border-primary pb-1">Torna alla Dashboard →</a>
    </div>
  </div>
</div>

<script>
  (function() {
    const API_URL = "https://trains-preventing-programs-vic.trycloudflare.com/public";
    const cid = "{{ customer.id }}";
    if (!cid) { window.location.href = "/account/login"; return; }

    const alertBox = document.getElementById('ticket-plan-alert');
    const alertText = document.getElementById('alert-text');
    const priorityBadge = document.getElementById('priority-badge');
    const cleanId = cid.split('/').pop();

    let userRole = "Base";

    // 1. CARICAMENTO RUOLO PER PERSONALIZZARE MODULO
    fetch(`${API_URL}/customer-data/${cleanId}`)
      .then(res => res.json())
      .then(data => {
        userRole = data.role || "Base";
        if(userRole.toLowerCase().includes('gold') || userRole.toLowerCase().includes('vip')) {
          alertBox.className = "p-6 rounded-3xl bg-emerald-50 border border-emerald-200 text-emerald-800 text-sm font-medium flex items-center gap-4 italic";
          alertText.innerText = `Come Membro ${userRole.replace('_',' ')}, la tua segnalazione ha Priorità Alta ed è inclusa nel piano.`;
          priorityBadge.innerText = "ALTA (SOS VIP)";
          priorityBadge.className = priorityBadge.className.replace('opacity-50', 'bg-emerald-600 text-white opacity-100');
        } else {
          alertBox.className = "p-6 rounded-3xl bg-amber-50 border border-amber-200 text-amber-800 text-sm font-medium flex items-center gap-4 italic";
          alertText.innerText = "Attenzione: Come Membro Base, l'uscita tecnica o l'analisi dedicata ha un costo forfettario di €100.";
        }
      });

    // 2. INVIO SEGNALAZIONE
    document.getElementById('jolly-ticket-form').addEventListener('submit', function(e) {
      e.preventDefault();
      const btn = document.getElementById('submit-btn');
      btn.disabled = true;
      btn.innerText = "INVIO IN CORSO...";

      const payload = {
        customerId: `gid://shopify/Customer/${cleanId}`,
        type: document.getElementById('ticket-type').value,
        description: document.getElementById('ticket-desc').value,
        priority: (userRole.toLowerCase().includes('gold') || userRole.toLowerCase().includes('vip')) ? "High" : "Normal"
      };

      fetch(`${API_URL}/create-ticket`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      })
      .then(res => res.json())
      .then(res => {
        if(res.success) {
          document.getElementById('jolly-ticket-form').classList.add('hidden');
          document.getElementById('ticket-plan-alert').classList.add('hidden');
          document.getElementById('success-msg').classList.remove('hidden');
        }
      })
      .catch(() => {
        alert("Errore di rete. Riprova.");
        btn.disabled = false;
        btn.innerText = "Invia Segnalazione";
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Ticket Form",
  "settings": []
}
{% endschema %}

