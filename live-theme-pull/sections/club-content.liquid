{% comment %}
  Dashboard Jolly Care Unificata 2026 - Versione 3.7 (Full Dynamic + SOS WhatsApp)
  Branding: Jolly Game Blue (#00578E) & Care Gold (#FFDEA5)
  Focus: 2-Row Telemetry, Care Identity, In-Store Benefits
{% endcomment %}

{% assign user_role = customer.metafields.custom.livello_abbonamento | default: 'Base' %}
{% assign is_gold = false %}
{% if user_role contains 'Gold' or user_role contains 'gold' %}
  {% assign is_gold = true %}
{% endif %}

<div class="max-w-7xl mx-auto space-y-10 md:space-y-16 py-8 md:py-12 px-4 sm:px-6 lg:px-8 text-primary font-sans space-y-24">
  
  <!-- 1. HERO DINAMICO (MOBILE FIRST) -->
  <section class="relative overflow-hidden rounded-[40px] md:rounded-[64px] {% if is_gold %}bg-[#001945]{% else %}bg-[#00578E]{% endif %} text-white p-8 md:p-24 shadow-2xl border border-white/10 transition-colors duration-1000">
      <div class="absolute inset-0 opacity-20 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-[#FFDEA5] to-transparent pointer-events-none animate-pulse"></div>
      <div class="relative z-10 max-w-4xl">
          <span class="inline-flex items-center gap-2 bg-white/10 px-4 py-1.5 rounded-full text-[8px] md:text-[10px] font-black mb-6 md:mb-10 tracking-[0.3em] uppercase backdrop-blur-xl border border-white/20">
              <span class="material-symbols-outlined text-[14px] md:text-[18px] text-[#FFDEA5]">shield</span>
              {% if is_gold %}Membro Jolly Care GOLD Attivo{% else %}Il Futuro della tua Piscina è Jolly Care{% endif %}
          </span>
          
          {% if is_gold %}
            <h1 class="text-4xl md:text-7xl font-headline font-extrabold tracking-tighter mb-6 md:mb-8 leading-none">
                Bentornato nel <br/><span class="text-[#FFDEA5] italic">Control Center.</span>
            </h1>
            <p class="text-base md:text-xl text-white/70 font-light leading-relaxed max-w-2xl italic">
              Il tuo Blue Connect sta monitorando ogni goccia. Rilassati, alla tua piscina pensiamo noi.
            </p>
          {% else %}
            <h1 class="text-4xl md:text-8xl font-headline font-extrabold tracking-tighter mb-6 md:mb-8 leading-[0.9]">
                Piscina <br/><span class="text-[#FFDEA5] italic">Senza Pensieri.</span>
            </h1>
            <p class="text-base md:text-2xl text-white/80 font-light leading-relaxed max-w-2xl mb-8 md:mb-12 italic">
              Gestione proattiva e diagnostica cloud. Diventa il custode del tuo relax con Jolly Care.
            </p>
            {% if customer == nil %}
              <div class="flex flex-wrap gap-4 md:gap-6">
                  <a href="/account/register" class="bg-[#FFDEA5] text-[#00578E] px-8 md:px-12 py-4 md:py-5 rounded-2xl md:rounded-3xl font-black text-[10px] md:text-xs uppercase tracking-widest hover:scale-105 transition-all shadow-2xl">Registrati Gratis</a>
                  <a href="/account/login" class="bg-white/10 border border-white/20 text-white px-8 md:px-12 py-4 md:py-5 rounded-2xl md:rounded-3xl font-black text-[10px] md:text-xs uppercase tracking-widest hover:bg-white/20 transition-all">Accedi</a>
              </div>
            {% endif %}
          {% endif %}
      </div>
  </section>

  <!-- 2. JOLLY CARE HUB (SOLO PER ISCRITTI) -->
  {% if customer %}
    <section id="jolly-care-hub" class="space-y-8 md:space-y-12">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-4 md:gap-6 border-b border-outline-variant/20 pb-8 md:pb-10">
            <div class="space-y-2">
                <h2 class="text-4xl md:text-5xl font-black uppercase italic tracking-tighter text-[#00578E] leading-none">Jolly <span class="text-[#FFDEA5] drop-shadow-sm">Care Hub</span></h2>
                <p class="text-outline font-bold text-[8px] md:text-[10px] uppercase tracking-[0.3em]">Sincronizzazione Cloud & Asset Management</p>
            </div>
            <div id="status-badge" class="bg-[#00578E] text-white px-6 md:px-10 py-3 md:py-4 rounded-full font-black text-[8px] md:text-[10px] uppercase tracking-[0.3em] shadow-lg">
                Membro {{ user_role | replace: 'VIP_', '' | replace: 'Gold', 'GOLD' }}
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
            <!-- DASHBOARD PRINCIPALE -->
            <div class="lg:col-span-8 space-y-8">
                <div class="bg-[#001945] p-8 md:p-12 rounded-[48px] md:rounded-[64px] shadow-2xl border border-white/5 relative overflow-hidden text-white">
                    <div class="absolute top-0 right-0 p-8 md:p-12 opacity-5 pointer-events-none">
                        <span class="material-symbols-outlined text-[150px] md:text-[250px]">shield</span>
                    </div>

                    <div class="relative z-10 space-y-10">
                        <!-- TELEMETRIA 2 RIGHE -->
                        <div class="space-y-8">
                            <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
                                <h4 class="text-xl md:text-2xl font-black uppercase italic tracking-tighter text-[#FFDEA5]">Stato Salute Piscina</h4>
                                <p id="tele-source" class="text-[8px] md:text-[9px] font-bold text-white/40 uppercase tracking-widest italic">In attesa...</p>
                            </div>

                            <div class="grid grid-cols-1 gap-6">
                                <!-- RIGA 1: PARAMETRI ACQUA -->
                                <div class="grid grid-cols-3 gap-4">
                                    <div id="card-ph" class="bg-white/5 p-6 rounded-3xl border border-white/5 text-center space-y-3 transition-all group hover:bg-white/10">
                                        <span class="material-symbols-outlined text-white/30 text-xl group-hover:text-[#FFDEA5] transition-colors">water_drop</span>
                                        <p id="tele-ph" class="text-3xl md:text-5xl font-black italic">--</p>
                                        <p class="text-[8px] font-bold text-white/40 uppercase tracking-widest">Livello pH</p>
                                    </div>
                                    <div id="card-orp" class="bg-white/5 p-6 rounded-3xl border border-white/5 text-center space-y-3 transition-all group hover:bg-white/10">
                                        <span class="material-symbols-outlined text-white/30 text-xl group-hover:text-[#FFDEA5] transition-colors">science</span>
                                        <p id="tele-orp" class="text-3xl md:text-5xl font-black italic">--</p>
                                        <p class="text-[8px] font-bold text-white/40 uppercase tracking-widest">ORP mV</p>
                                    </div>
                                    <div id="card-cond" class="bg-white/5 p-6 rounded-3xl border border-white/5 text-center space-y-3 transition-all group hover:bg-white/10">
                                        <span class="material-symbols-outlined text-white/30 text-xl group-hover:text-[#FFDEA5] transition-colors">electric_bolt</span>
                                        <p id="tele-cond" class="text-3xl md:text-5xl font-black italic">--</p>
                                        <p class="text-[8px] font-bold text-white/40 uppercase tracking-widest">Salinità µS</p>
                                    </div>
                                </div>
                                <!-- RIGA 2: TEMPERATURE -->
                                <div class="grid grid-cols-2 gap-4">
                                    <div id="card-temp" class="bg-white/5 p-6 rounded-3xl border border-white/5 flex items-center justify-between px-10 transition-all group hover:bg-white/10">
                                        <div class="space-y-1">
                                            <p class="text-[8px] font-bold text-white/40 uppercase tracking-widest">Acqua</p>
                                            <p id="tele-temp" class="text-3xl md:text-4xl font-black italic">--</p>
                                        </div>
                                        <span class="material-symbols-outlined text-white/20 text-4xl">thermostat</span>
                                    </div>
                                    <div id="card-meteo" class="bg-white/5 p-6 rounded-3xl border border-white/5 flex items-center justify-between px-10 transition-all group hover:bg-white/10">
                                        <div class="space-y-1">
                                            <p class="text-[8px] font-bold text-white/40 uppercase tracking-widest">Meteo Est.</p>
                                            <p id="tele-meteo" class="text-3xl md:text-4xl font-black italic">--</p>
                                        </div>
                                        <span class="material-symbols-outlined text-white/20 text-4xl">cloud</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="pt-8 border-t border-white/10">
                            <div id="health-signals">
                                <div class="flex items-center gap-4 text-emerald-400">
                                    <span class="material-symbols-outlined text-sm">verified</span>
                                    <p class="text-[10px] md:text-xs font-bold uppercase tracking-widest italic">Sincronizzazione Cloud Attiva.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- BANNER SCONTO IN NEGOZIO -->
                <div class="bg-gradient-to-br from-[#FFDEA5] to-[#fcebb6] p-8 md:p-10 rounded-[48px] flex flex-col md:flex-row items-center justify-between gap-8 shadow-xl border border-white/20">
                    <div class="flex-1 space-y-2 text-center md:text-left text-[#00578E]">
                        <h4 class="text-2xl font-black uppercase italic tracking-tight leading-none">Vantaggi In-Store 🏷️</h4>
                        <p class="text-sm font-bold opacity-70 italic leading-relaxed">Presenta la tua Care Identity nel centro Jolly Game di Guidonia per ricevere sconti esclusivi sull'acquisto di accessori e ricambi.</p>
                    </div>
                    <div class="bg-[#00578E] text-[#FFDEA5] px-8 py-4 rounded-2xl font-black text-xs uppercase tracking-widest shadow-lg">Sconto 10% Live</div>
                </div>
            </div>

            <!-- SIDEBAR HUB -->
            <div class="lg:col-span-4 space-y-8">
                <!-- SOS WHATSAPP VIP BUTTON -->
                {%- assign role_clean = user_role | downcase -%}
                {%- if role_clean contains 'pro' or role_clean contains 'gold' -%}
                    <a href="https://wa.me/393281234567?text=SOS%20Jolly%20Care:%20Assistenza%20Membro%20VIP" target="_blank" class="bg-[#25D366] text-white p-10 rounded-[48px] shadow-2xl flex flex-col items-center text-center group hover:scale-105 transition-all border-4 border-white/20 relative overflow-hidden">
                        <div class="absolute -right-4 -top-4 opacity-20 group-hover:rotate-12 transition-transform">
                            <span class="material-symbols-outlined text-8xl">forum</span>
                        </div>
                        <span class="material-symbols-outlined text-5xl mb-4">bolt</span>
                        <h4 class="text-2xl font-black uppercase italic tracking-tight leading-none">SOS WHATSAPP</h4>
                        <p class="text-[10px] font-bold uppercase tracking-widest mt-4 opacity-80 italic">Linea Diretta 15min</p>
                    </a>
                {%- else -%}
                    <div class="bg-[#25D366]/5 p-10 rounded-[48px] border-2 border-dashed border-[#25D366]/20 flex flex-col items-center text-center opacity-60">
                        <span class="material-symbols-outlined text-4xl text-[#25D366] mb-4 opacity-40">lock</span>
                        <h4 class="text-xl font-black uppercase italic text-[#00578E]">WhatsApp SOS</h4>
                        <p class="text-[8px] font-bold uppercase tracking-widest mt-2">Esclusivo PRO / GOLD</p>
                    </div>
                {%- endif -%}

                <!-- CARE IDENTITY -->
                <div class="bg-white p-10 rounded-[48px] border border-outline-variant/15 flex flex-col items-center text-center shadow-sm group hover:shadow-xl transition-all duration-500 relative overflow-hidden">
                    <div class="absolute -right-6 -top-6 opacity-5 group-hover:scale-110 transition-transform text-[#00578E]">
                        <span class="material-symbols-outlined text-9xl">qr_code_2</span>
                    </div>
                    <h3 class="font-black text-xl mb-2 text-[#00578E] uppercase tracking-tighter italic">Care Identity</h3>
                    <p class="text-[9px] text-on-surface-variant mb-8 font-bold opacity-60 uppercase tracking-widest">Riconoscimento Ufficiale</p>
                    
                    <div class="bg-surface-container-low p-8 rounded-3xl shadow-inner mb-8 relative w-full flex items-center justify-center min-h-[180px] border border-outline-variant/10 group-hover:border-[#00578E]/20 transition-all">
                        <span class="material-symbols-outlined text-8xl text-[#00578E] opacity-10 group-hover:opacity-30 transition-all">qr_code_2</span>
                        <div class="absolute inset-0 border-[8px] border-white rounded-3xl pointer-events-none shadow-sm"></div>
                    </div>
                    <p class="text-[10px] font-mono text-outline font-black tracking-[0.4em] uppercase mb-8">NODE: {{ customer.id | slice: 0, 12 }}</p>
                    <div class="text-[9px] font-black uppercase tracking-widest text-[#00578E] bg-[#FFDEA5]/20 px-4 py-2 rounded-full">Identità Jolly Care ✅</div>
                </div>

                <!-- SETUP PISCINA -->
                <div class="bg-surface-container-low p-10 rounded-[48px] space-y-8 border border-outline-variant/10">
                    <div class="space-y-2">
                        <p class="text-[10px] font-black text-[#00578E] uppercase tracking-widest opacity-50">Dati Tecnici</p>
                        <h4 class="text-2xl font-black italic uppercase leading-none text-[#00578E]">Asset Piscina</h4>
                    </div>
                    <div class="space-y-6">
                        <div class="flex items-center gap-4">
                            <div class="w-10 h-10 bg-white rounded-xl flex items-center justify-center text-[#00578E] shadow-sm"><span class="material-symbols-outlined text-xl">water_damage</span></div>
                            <div>
                                <p id="val-vol" class="text-lg font-black text-[#00578E] italic">--</p>
                                <p class="text-[7px] font-bold uppercase tracking-widest opacity-40">Volume</p>
                            </div>
                        </div>
                        <div class="flex items-center gap-4">
                            <div class="w-10 h-10 bg-white rounded-xl flex items-center justify-center text-[#00578E] shadow-sm"><span class="material-symbols-outlined text-xl">filter_alt</span></div>
                            <div>
                                <p id="val-fil" class="text-lg font-black text-[#00578E] italic">--</p>
                                <p class="text-[7px] font-bold uppercase tracking-widest opacity-40">Filtrazione</p>
                            </div>
                        </div>
                    </div>
                    <button onclick="toggleMode(true)" class="w-full bg-white text-[#00578E] py-4 rounded-2xl font-black text-[9px] uppercase tracking-widest shadow-sm hover:bg-[#00578E] hover:text-white transition-all">Modifica Setup</button>
                </div>
            </div>
        </div>

        <!-- DASHBOARD EDIT (OVERLAY) -->
        <div id="edit-mode" class="hidden fixed inset-0 z-[100] flex items-center justify-center p-4 bg-[#001945]/95 backdrop-blur-2xl animate-in fade-in duration-300">
            <div class="bg-white p-8 md:p-16 rounded-[40px] md:rounded-[64px] shadow-2xl max-w-4xl w-full relative">
                <button onclick="toggleMode(false)" class="absolute top-6 md:top-10 right-6 md:right-10 text-outline hover:text-[#00578E] transition-colors"><span class="material-symbols-outlined text-3xl md:text-4xl">close</span></button>
                
                <div class="space-y-8 md:space-y-12 text-[#00578E]">
                    <div class="space-y-2">
                        <h3 class="text-3xl md:text-4xl font-black uppercase italic tracking-tighter leading-none">Setup <span class="text-[#FFDEA5] bg-[#00578E] px-3 py-1 rounded-xl not-italic">Piscina</span></h3>
                        <p class="text-outline font-bold text-[8px] md:text-[10px] uppercase tracking-widest">Aggiorna i parametri tecnici della tua piscina</p>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-10">
                        <div class="space-y-3">
                            <label class="block text-[8px] md:text-[10px] font-black uppercase tracking-[0.2em]">Volume Piscina (m³)</label>
                            <input type="number" id="in-vol" class="w-full p-5 md:p-6 rounded-2xl md:rounded-3xl bg-surface-container-low border border-outline-variant text-2xl md:text-3xl font-black outline-none focus:border-[#00578E] transition-all">
                        </div>
                        <div class="space-y-3">
                            <label class="block text-[8px] md:text-[10px] font-black uppercase tracking-[0.2em]">Filtrazione</label>
                            <select id="in-fil" class="w-full p-5 md:p-6 rounded-2xl md:rounded-3xl bg-surface-container-low border border-outline-variant text-lg md:text-xl font-black uppercase italic outline-none h-[62px] md:h-[82px]">
                                <option value="sabbia">Sabbia Quarzo</option>
                                <option value="vetro">Vetro Attivato</option>
                                <option value="cartuccia">Cartuccia / Calza</option>
                                <option value="diatomee">Diatomee</option>
                            </select>
                        </div>
                        <div class="md:col-span-2 space-y-3">
                            <label class="block text-[8px] md:text-[10px] font-black uppercase tracking-[0.2em]">Modello Pompa Installata</label>
                            <input type="text" id="in-pmp" class="w-full p-5 md:p-6 rounded-2xl md:rounded-3xl bg-surface-container-low border border-outline-variant text-lg md:text-xl font-black uppercase italic outline-none focus:border-[#00578E] transition-all">
                        </div>
                    </div>

                    <div class="flex flex-col sm:flex-row gap-4 md:gap-6">
                        <button onclick="toggleMode(false)" class="order-2 sm:order-1 flex-1 py-5 rounded-2xl md:rounded-3xl font-black text-xs uppercase tracking-widest text-outline hover:bg-surface-container transition-all border border-outline-variant/30">Annulla</button>
                        <button id="save-btn" class="order-1 sm:order-2 flex-[2] bg-[#00578E] text-white py-5 rounded-2xl md:rounded-3xl font-black text-xs uppercase tracking-widest shadow-xl hover:scale-105 transition-all">Salva nel Cloud</button>
                    </div>
                </div>
            </div>
        </div>
    </section>
  {% endif %}

  <!-- 3. LANDING PIANI (SOLO PER NON-GOLD) -->
  {% unless is_gold %}
  {% assign sub_product = all_products['abbonamento-jolly-care'] %}
  <section id="piani" class="space-y-12 md:space-y-16 py-10 border-t border-outline-variant/20">
      <div class="text-center space-y-4">
          <h2 class="text-4xl md:text-7xl font-black uppercase italic tracking-tighter text-[#00578E] leading-none">Jolly <span class="text-[#FFDEA5] drop-shadow-sm">Care.</span></h2>
          <p class="text-on-surface-variant font-medium text-lg md:text-xl max-w-2xl mx-auto italic opacity-70">
            Scegli il livello di protezione adatto alla tua oasi di relax.
          </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <!-- BASE -->
          <div class="bg-white p-10 md:p-12 rounded-[48px] md:rounded-[56px] border border-outline-variant/20 flex flex-col justify-between group shadow-sm hover:shadow-xl transition-all">
              <div class="space-y-10">
                  <div class="space-y-2">
                      <h3 class="text-3xl font-black uppercase italic tracking-tighter text-[#00578E]">Membro Base</h3>
                      <p class="text-[10px] font-black uppercase tracking-widest text-outline">Hub Access</p>
                  </div>
                  <div class="text-6xl font-black italic text-[#00578E]">Free</div>
                  <ul class="space-y-6 text-xs font-bold uppercase tracking-widest opacity-70 text-[#00578E]">
                      <li class="flex items-center gap-4"><span class="material-symbols-outlined text-emerald-500">check_circle</span> Cartella Clinica Cloud</li>
                      <li class="flex items-center gap-4"><span class="material-symbols-outlined text-emerald-500">check_circle</span> Accesso allo Shop</li>
                      <li class="flex items-center gap-4 opacity-30"><span class="material-symbols-outlined">block</span> Assistenza SOS VIP</li>
                  </ul>
              </div>
              {% if customer %}
                <div class="mt-12 w-full bg-surface-container text-[#00578E] py-6 rounded-3xl font-black text-[10px] uppercase tracking-widest text-center border-2 border-dashed border-outline-variant/30">Livello Attivo ✅</div>
              {% else %}
                <a href="/account/register" class="mt-12 w-full bg-[#00578E] text-white py-6 rounded-3xl font-black text-[10px] uppercase tracking-widest text-center shadow-xl hover:brightness-110 transition-all">Registrati Gratis</a>
              {% endif %}
          </div>

          <!-- PRO -->
          {% assign pro_variant = sub_product.variants | where: "title", "Pro" | first %}
          <div class="bg-[#00578E] p-10 md:p-12 rounded-[48px] md:rounded-[56px] text-white shadow-2xl relative overflow-hidden flex flex-col justify-between group border border-white/10 scale-105 z-10">
              <div class="absolute top-0 right-0 bg-[#FFDEA5] text-[#00578E] px-8 py-3 rounded-bl-3xl font-black text-[10px] uppercase tracking-widest">RACCOMANDATO</div>
              <div class="space-y-10">
                  <div class="space-y-2">
                      <h3 class="text-3xl font-black uppercase italic tracking-tighter text-[#FFDEA5]">Jolly Care Pro</h3>
                      <p class="text-[10px] font-black uppercase tracking-widest text-white/50">Protezione Attiva</p>
                  </div>
                  <div class="text-6xl font-black mb-12 tracking-tighter italic">{{ pro_variant.price | money_without_trailing_zeros }}<span class="text-xl font-normal opacity-60">/mese</span></div>
                  <ul class="space-y-6 mb-12 font-bold text-xs uppercase tracking-widest">
                      <li class="flex items-center gap-4"><span class="material-symbols-outlined text-[#FFDEA5]">check_circle</span> Vantaggi Base Inclusi</li>
                      <li class="flex items-center gap-4"><span class="material-symbols-outlined text-[#FFDEA5]">bolt</span> Linea SOS WhatsApp</li>
                      <li class="flex items-center gap-4"><span class="material-symbols-outlined text-[#FFDEA5]">forum</span> WhatsApp Direct Line</li>
                  </ul>
              </div>
              <button onclick="buyPlan('{{ pro_variant.id }}')" class="w-full bg-[#FFDEA5] text-[#00578E] py-6 md:py-7 rounded-3xl font-black text-[10px] uppercase tracking-widest hover:scale-105 transition-all shadow-2xl">
                {% if user_role contains 'Pro' %}LIVELLO ATTIVO{% else %}Attiva Jolly Care Pro{% endif %}
              </button>
          </div>

          <!-- GOLD -->
          {% assign gold_variant = sub_product.variants | where: "title", "Gold" | first %}
          <div class="bg-[#001945] p-10 md:p-12 rounded-[48px] md:rounded-[56px] text-white shadow-xl border-4 border-[#FFDEA5] flex flex-col justify-between relative group overflow-hidden">
              <div class="absolute -right-10 -top-10 opacity-10 text-white group-hover:rotate-12 transition-transform duration-1000">
                  <span class="material-symbols-outlined text-[200px]">diamond</span>
              </div>
              <div class="relative z-10">
                  <h3 class="text-3xl font-black mb-2 uppercase italic tracking-tighter flex items-center gap-3 text-[#FFDEA5]">Membro GOLD 💎</h3>
                  <p class="text-white/60 text-sm mb-10 font-medium leading-relaxed italic opacity-60">La delega totale ai nostri ingegneri.</p>
                  <div class="text-6xl font-black mb-12 tracking-tighter italic text-[#FFDEA5]">{{ gold_variant.price | money_without_trailing_zeros }}<span class="text-xl font-normal text-white/40">/mese</span></div>
                  <ul class="space-y-6 mb-12 font-bold text-xs uppercase tracking-widest">
                      <li class="flex items-center gap-4"><span class="material-symbols-outlined text-[#FFDEA5]">sync</span> Blue Connect Incluso</li>
                      <li class="flex items-center gap-4"><span class="material-symbols-outlined text-[#FFDEA5]">bolt</span> Linea SOS WhatsApp</li>
                      <li class="flex items-center gap-4"><span class="material-symbols-outlined text-[#FFDEA5]">local_shipping</span> Refill Automatico</li>
                  </ul>
              </div>
              <button onclick="buyPlan('{{ gold_variant.id }}')" class="w-full border-4 border-[#FFDEA5] text-[#FFDEA5] py-6 rounded-3xl font-black text-[10px] uppercase tracking-widest hover:bg-[#FFDEA5] hover:text-[#001945] transition-all shadow-lg">Passa a Gold</button>
          </div>
      </div>
  </section>
  {% endunless %}

  <!-- 4. FOOTER LINKS (MOBILE FIRST) -->
  <section class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8 pt-10 border-t border-outline-variant/20">
      <a href="/pages/assistance" class="bg-surface-container-low p-8 md:p-10 rounded-[40px] md:rounded-[48px] flex items-center gap-6 md:gap-8 group hover:bg-white hover:shadow-xl transition-all border border-transparent hover:border-outline-variant/20">
          <div class="bg-[#00578E] text-white p-5 md:p-6 rounded-2xl md:rounded-3xl group-hover:scale-110 transition-transform shadow-lg"><span class="material-symbols-outlined text-3xl md:text-4xl">support_agent</span></div>
          <div>
              <h4 class="text-lg md:text-xl font-black uppercase italic tracking-tighter text-[#00578E]">Assistenza Specialistica</h4>
              <p class="text-xs md:text-sm font-medium opacity-60 italic text-outline">Richiedi un intervento o consulenza tecnica.</p>
              <span class="text-[#00578E] font-black text-[9px] md:text-[10px] uppercase tracking-widest mt-3 md:mt-4 inline-block border-b-2 border-[#00578E] pb-1">Nuova Segnalazione →</span>
          </div>
      </a>
      <a href="/pages/jolly-care-termini" class="bg-surface-container-low p-8 md:p-10 rounded-[40px] md:rounded-[48px] flex items-center gap-6 md:gap-8 group hover:bg-white hover:shadow-xl transition-all border border-transparent hover:border-outline-variant/20">
          <div class="bg-[#FFDEA5] text-[#00578E] p-5 md:p-6 rounded-2xl md:rounded-3xl group-hover:scale-110 transition-transform shadow-lg"><span class="material-symbols-outlined text-3xl md:text-4xl">menu_book</span></div>
          <div>
              <h4 class="text-lg md:text-xl font-black uppercase italic tracking-tighter text-[#00578E]">Documentazione</h4>
              <p class="text-xs md:text-sm font-medium opacity-60 italic text-outline">FAQ, Piani e Condizioni Jolly Care.</p>
              <span class="text-[#00578E] font-black text-[9px] md:text-[10px] uppercase tracking-widest mt-3 md:mt-4 inline-block border-b-2 border-[#00578E] pb-1">Scopri di più →</span>
          </div>
      </a>
  </section>
</div>

<script>
  (function() {
    const API_URL = "https://trains-preventing-programs-vic.trycloudflare.com/public";
    const SELLING_PLAN_ID = "692465828188";

    window.toggleMode = function(edit) {
      const e = document.getElementById('edit-mode');
      if(e) e.classList.toggle('hidden', !edit);
    };

    window.buyPlan = function(variantId) {
      {% if customer %}
        const btn = event.currentTarget;
        const oldText = btn.innerText;
        btn.innerText = "ATTESA...";
        btn.disabled = true;

        fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            items: [{ id: variantId, quantity: 1, selling_plan: SELLING_PLAN_ID }]
          })
        })
        .then(() => { window.location.href = "/checkout"; })
        .catch(() => {
          alert("Errore tecnico. Riprova.");
          btn.disabled = false;
          btn.innerText = oldText;
        });
      {% else %}
        window.location.href = "/account/register";
      {% endif %}
    }

    {% if customer %}
      const CID = "{{ customer.id }}".split('/').pop();
      const GID = "gid://shopify/Customer/" + CID;
      
      // 1. RECUPERO DATI HUB
      fetch(`${API_URL}/customer-data/${CID}?t=${Date.now()}`)
        .then(res => res.json())
        .then(data => {
          document.getElementById('val-vol').innerText = data.volume ? `${data.volume} m³` : '--';
          document.getElementById('val-fil').innerText = data.filter || '--';
          document.getElementById('val-pmp').innerText = data.pump || '--';

          document.getElementById('in-vol').value = data.volume || "";
          document.getElementById('in-fil').value = data.filter || "sabbia";
          document.getElementById('in-pmp').value = data.pump || "";
        });

      // 2. LOGICA TELEMETRIA & SEGNALI BENESSERE
      const IS_GOLD = {{ is_gold }};
      const updateDisplay = (data) => {
         if(!data) return;
         const ph = parseFloat(data.ph);
         const orp = parseInt(data.orp);
         const temp = parseFloat(data.temp);
         const cond = parseInt(data.cond);
         const meteo = parseFloat(data.meteo_temp || data.meteo);

         if(document.getElementById('tele-temp')) document.getElementById('tele-temp').innerText = temp ? `${temp}°` : '--';
         if(document.getElementById('tele-ph')) document.getElementById('tele-ph').innerText = ph || '--';
         if(document.getElementById('tele-orp')) document.getElementById('tele-orp').innerText = orp || '--';
         if(document.getElementById('tele-cond')) document.getElementById('tele-cond').innerText = cond || '--';
         if(document.getElementById('tele-meteo')) document.getElementById('tele-meteo').innerText = meteo ? `${meteo}°` : '--';
         if(document.getElementById('tele-source')) document.getElementById('tele-source').innerText = data.timestamp ? `Update: ${new Date(data.timestamp).toLocaleTimeString()}` : 'In attesa...';
         
         const signalsBox = document.getElementById('health-signals');
         let signalsHtml = '';

         if(orp < 600) {
            signalsHtml += `<div class="flex items-center gap-4 text-red-400 animate-pulse"><span class="material-symbols-outlined">warning</span><p class="text-xs font-bold uppercase tracking-widest italic text-red-400">Cloro Basso. Refill Suggerito.</p></div>`;
            document.getElementById('card-orp').className = "bg-red-500/10 p-4 md:p-6 rounded-2xl md:rounded-3xl border border-red-500/30 text-center space-y-2 md:space-y-3 transition-all";
         } else {
            document.getElementById('card-orp').className = "bg-white/5 p-4 md:p-6 rounded-2xl md:rounded-3xl border border-white/5 text-center space-y-2 md:space-y-3 transition-all";
         }

         if(ph < 7.0 || ph > 7.8) {
            signalsHtml += `<div class="flex items-center gap-4 text-[#FFDEA5]"><span class="material-symbols-outlined">error</span><p class="text-xs font-bold uppercase tracking-widest italic text-[#FFDEA5]">pH Fuori Range. Regolare.</p></div>`;
            document.getElementById('card-ph').className = "bg-[#FFDEA5]/10 p-4 md:p-6 rounded-2xl md:rounded-3xl border border-[#FFDEA5]/30 text-center space-y-2 md:space-y-3 transition-all";
         } else {
            document.getElementById('card-ph').className = "bg-white/5 p-4 md:p-6 rounded-2xl md:rounded-3xl border border-white/5 text-center space-y-2 md:space-y-3 transition-all";
         }

         if(!signalsHtml) {
            signalsHtml = `<div class="flex items-center gap-4 text-emerald-400"><span class="material-symbols-outlined">verified</span><p class="text-xs font-bold uppercase tracking-widest italic leading-relaxed">Parametri Ottimali.</p></div>`;
         }
         signalsBox.innerHTML = signalsHtml;
      };

      fetch(`${API_URL}/telemetry/${CID}`)
        .then(res => res.json())
        .then(data => updateDisplay(data));
      
      if (IS_GOLD) {
        setInterval(() => {
           fetch(`${API_URL}/telemetry/${CID}?t=${Date.now()}`)
             .then(res => res.json())
             .then(data => updateDisplay(data));
        }, 30000);
      }

      document.getElementById('save-btn').addEventListener('click', function() {
        const btn = this;
        btn.disabled = true;
        btn.innerText = "ATTESA...";
        fetch(`${API_URL}/update-pool`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            customerId: GID,
            volume: document.getElementById('in-vol').value,
            filtro: document.getElementById('in-fil').value,
            pompa: document.getElementById('in-pmp').value
          })
        })
        .then(() => { window.location.reload(); });
      });
    {% endif %}
  })();
</script>

{% schema %}
{
  "name": "Club Dashboard Unificata",
  "settings": []
}
{% endschema %}
