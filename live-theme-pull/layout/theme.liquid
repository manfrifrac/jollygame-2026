<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="#0268a6">
    <link rel="canonical" href="{{ canonical_url }}">

    <title>
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    </title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    {% render 'meta-tags' %}

    <!-- Google Fonts & Material Symbols -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />

    <!-- Tailwind CSS CDN (For Prototype) -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              primary: '#0268a6',
              'primary-fixed': '#d9e2ff',
              'on-primary-fixed': '#001945',
              'primary-fixed-dim': '#adc6ff',
              secondary: '#585e71',
              tertiary: '#73575d',
              'tertiary-fixed': '#ffdea5',
              'on-tertiary-fixed': '#281900',
              error: '#ba1a1a',
              background: '#fdfbff',
              'on-surface': '#1b1b1f',
              'on-surface-variant': '#44474e',
              'outline': '#74777f',
              'outline-variant': '#c4c6d0',
              'surface-container-low': '#f7f3f7',
              'surface-container-lowest': '#ffffff',
            },
            fontFamily: {
              sans: ['Inter', 'sans-serif'],
              headline: ['Inter', 'sans-serif'],
            },
            animation: {
              'bounce-slow': 'bounce 3s infinite',
            }
          }
        }
      }
    </script>

    {{ content_for_header }}

    <style>
      [v-cloak] { display: none; }
      .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
      }
      body {
        font-family: 'Inter', sans-serif;
      }
      .water-gradient {
        background: linear-gradient(135deg, #0268a6 0%, #0044cc 100%);
      }
    </style>
  </head>

  <body class="bg-background text-on-surface flex flex-col min-h-screen overflow-x-hidden">
    
    {% sections 'header-group' %}

    <main id="MainContent" class="flex-1 focus:outline-none" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>

    {% section 'footer-mobile' %}
    {% section 'footer' %}

    <!-- WhatsApp Widget -->
    {%- assign phone_number = shop.phone | default: '390774345316' | replace: '+', '' | replace: ' ', '' | replace: '-', '' | replace: '(', '' | replace: ')', '' -%}
    <a href="https://wa.me/{{ phone_number }}" target="_blank" class="fixed bottom-6 right-6 z-50 flex items-center gap-2 px-4 py-3 bg-green-500 text-white rounded-full shadow-xl hover:bg-green-600 hover:scale-105 transition-all duration-300">
      <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.372-.025-.52-.075-.149-.67-1.612-.916-2.207-.242-.579-.487-.5-.67-.509-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.463 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.549 4.142 1.594 5.945L.057 24l6.438-1.688a11.84 11.84 0 0 0 5.617 1.43l.006.002c6.554 0 11.89-5.335 11.894-11.893.003-6.556-5.331-11.891-11.89-11.891"/>
      </svg>
      <span class="font-semibold text-sm">Contattaci</span>
    </a>


    <script>
      window.shopUrl = '{{ request.origin }}';
      window.routes = {
        cart_add_url: '{{ routes.cart_add_url }}',
        cart_change_url: '{{ routes.cart_change_url }}',
        cart_update_url: '{{ routes.cart_update_url }}',
        cart_url: '{{ routes.cart_url }}',
      };
    </script>

    <!-- Theme Main JS -->
    <script src="{{ 'global.js' | asset_url }}" defer="defer"></script>
    <script src="{{ 'theme.js' | asset_url }}" defer="defer"></script>
  </body>
</html>
