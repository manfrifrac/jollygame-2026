{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .brand-ricambi-hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    margin-bottom: 2rem;
  }

  .brand-ricambi-logo img {
    max-width: 200px;
    height: auto;
    margin-bottom: 1rem;
  }

  .brand-ricambi-docs {
    margin-top: 3rem;
    padding: 2rem;
    background: #f4f4f4;
    border-radius: 8px;
  }

  .brand-ricambi-docs h2 {
    margin-top: 0;
  }

  .brand-ricambi-docs ul {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 1rem;
  }

  .brand-ricambi-docs li a {
    display: flex;
    align-items: center;
    padding: 1rem;
    background: white;
    border: 1px solid #ddd;
    border-radius: 4px;
    text-decoration: none;
    color: inherit;
    font-weight: bold;
    transition: background 0.2s;
  }

  .brand-ricambi-docs li a:hover {
    background: #eef;
  }
{%- endstyle -%}

<div class="max-w-7xl mx-auto py-12 px-4 sm:px-6 lg:px-8 text-primary font-sans">
  <!-- HERO SECTION -->
  <div class="text-center mb-16">
    {% if metaobject.logo %}
      <div class="inline-block p-6 bg-white rounded-3xl shadow-sm border border-outline-variant/10 mb-8">
        {{ metaobject.logo | image_url: width: 200 | image_tag: class: 'h-auto max-w-[150px]' }}
      </div>
    {% endif %}
    <h1 class="text-4xl md:text-5xl font-black uppercase italic tracking-tighter text-[#00578E] mb-6">{{ metaobject.nome.value }}</h1>
    <div class="rte text-lg text-on-surface-variant max-w-2xl mx-auto leading-relaxed">
      {% for child in metaobject.descrizione.value.children %}
        {% if child.type == 'paragraph' %}
          <p>
            {% for node in child.children %}
              {{ node.value }}
            {% endfor %}
          </p>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <!-- PRODUCTS GRID -->
  <div class="brand-ricambi-products">
    <h2 class="text-3xl font-black uppercase italic tracking-tighter text-[#00578E] mb-10">Ricambi Originali</h2>
    <ul class="grid grid-cols-1 md:grid-cols-2 gap-4" role="list">
      {%- assign ricambi_associati = metaobject.ricambi_associati.value -%}
      {%- if ricambi_associati != blank -%}
        {%- for ricambio in ricambi_associati -%}
          <li class="bg-white p-3 rounded-2xl border border-outline-variant/10 shadow-sm hover:border-[#00578E] transition-all flex items-center gap-4">
            <div class="w-16 h-16 shrink-0 bg-surface-container-low rounded-lg border border-outline-variant/10 flex items-center justify-center overflow-hidden">
              {%- if ricambio.immagine != blank -%}
                <img src="{{ ricambio.immagine.value | image_url: width: 100 }}" alt="{{ ricambio.nome.value | escape }}" class="w-full h-full object-contain" loading="lazy">
              {%- else -%}
                <span class="material-symbols-outlined text-outline opacity-50">build</span>
              {%- endif -%}
            </div>
            <div class="flex-1 min-w-0">
              <p class="font-bold text-xs text-primary truncate" title="{{ ricambio.nome.value }}">{{ ricambio.nome.value }}</p>
              <p class="text-[10px] text-outline font-bold mt-0.5">{{ ricambio.sku_originale.value }}</p>
              <a href="{{ ricambio.system.url }}" class="block mt-1.5 text-[10px] font-black uppercase text-[#00578E] hover:underline">Vedi Dettagli</a>
            </div>
          </li>
        {%- endfor -%}
      {%- else -%}
        <li class="text-xs text-outline italic">Nessun ricambio associato a questo brand.</li>
      {%- endif -%}
    </ul>
  </div>

  <!-- DOCUMENTATION -->
  {% if metaobject.documentazione.value.size > 0 %}
    <div class="bg-surface-container-low p-10 md:p-12 rounded-[40px] border border-outline-variant/10">
      <h2 class="text-2xl font-black uppercase italic tracking-tighter text-[#00578E] mb-8">Documentazione Tecnica e Esplosi</h2>
      <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {% for doc in metaobject.documentazione.value %}
          <li class="bg-white p-6 rounded-2xl shadow-sm border border-outline-variant/10 flex items-center gap-4 hover:border-[#00578E] transition-all">
            <span class="material-symbols-outlined text-[#00578E] text-2xl">description</span>
            <a href="{{ doc.url_file.value }}" target="_blank" class="font-bold text-primary hover:text-[#00578E] transition-colors">
              {{ doc.titolo.value }}
            </a>
          </li>
        {% endfor %}
      </ul>
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Brand Ricambi Page",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 36
    }
  ]
}
{% endschema %}
