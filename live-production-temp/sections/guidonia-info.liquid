<section class="bg-primary-fixed text-on-primary-fixed p-12 md:p-20 rounded-[48px] flex flex-col md:flex-row items-center justify-between gap-12 border border-primary/10 relative overflow-hidden shadow-sm max-w-7xl mx-auto mb-20">
    <div class="absolute left-0 bottom-0 opacity-10 pointer-events-none text-primary">
        <span class="material-symbols-outlined text-[200px]">storefront</span>
    </div>
    <div class="relative z-10 max-w-2xl text-center md:text-left text-primary">
        <h2 class="text-4xl md:text-5xl font-black tracking-tighter uppercase italic mb-6">Il Negozio di Guidonia</h2>
        <p class="text-lg font-medium opacity-80 leading-relaxed mb-8">
            Vieni a trovarci nel nostro centro autorizzato. Ordina online e ritira in negozio in un'ora. <b>Siamo vicini a te, sempre.</b>
        </p>
        <div class="flex flex-wrap justify-center md:justify-start gap-4">
            <a href="/pages/club" class="bg-primary text-white px-8 py-4 rounded-xl font-bold text-sm uppercase tracking-widest shadow-lg">Prenota Ritiro</a>
            <a href="https://maps.google.com" target="_blank" class="bg-white text-primary px-8 py-4 rounded-xl font-bold text-sm uppercase tracking-widest shadow-md">Come Arrivare</a>
        </div>
    </div>
    <div class="relative z-10 w-48 h-48 bg-white p-6 rounded-[32px] shadow-2xl flex items-center justify-center">
        <span class="material-symbols-outlined text-8xl text-primary opacity-20">qr_code_2</span>
        <div class="absolute inset-4 border-2 border-primary/10 rounded-2xl pointer-events-none border-dashed"></div>
    </div>
</section>

{% schema %}
{
  "name": "Guidonia Info",
  "settings": []
}
{% endschema %}
