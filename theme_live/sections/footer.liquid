{% comment %}
  Jolly Care Footer - Versione Streamlined 2026
  Design System: Rounded 48px, Dark Mode
{% endcomment %}

<footer class="bg-[#1b1b1f] pt-16 pb-12 border-t border-white/5 font-sans">
  <div class="max-w-7xl mx-auto px-6 md:px-10">
    
    <div class="grid grid-cols-1 md:grid-cols-12 gap-16 text-white pb-16">
        <!-- BRAND INFO -->
        <div class="md:col-span-4 space-y-8">
            <div class="inline-flex items-center justify-center p-4 bg-white rounded-2xl shadow-xl h-16">
                <img src="{{ 'logo.png' | asset_url }}" alt="{{ shop.name }}" class="h-full w-auto object-contain">
            </div>
            <p class="text-white/50 text-sm leading-relaxed max-w-xs italic">
                Jolly Care è l'ecosistema phygital di Jolly Game. Tecnologia cloud e competenza umana per la cura totale della tua piscina.
            </p>
            <div class="flex gap-4">
                {%- if settings.social_facebook_link != blank -%}
                    <a href="{{ settings.social_facebook_link }}" class="w-10 h-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center hover:bg-primary transition-all">
                        <span class="material-symbols-outlined text-xl">facebook</span>
                    </a>
                {%- endif -%}
                {%- if settings.social_instagram_link != blank -%}
                    <a href="{{ settings.social_instagram_link }}" class="w-10 h-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center hover:bg-primary transition-all">
                        <span class="material-symbols-outlined text-xl">photo_camera</span>
                    </a>
                {%- endif -%}
            </div>
        </div>

        <!-- LINKS -->
        <div class="md:col-span-8 grid grid-cols-2 md:grid-cols-3 gap-12">
            <div class="space-y-6">
                <h4 class="font-black uppercase text-[9px] tracking-[0.3em] text-tertiary-fixed opacity-80">Navigazione</h4>
                <ul class="space-y-4 font-bold text-xs uppercase tracking-widest text-white/70">
                    <li><a href="{{ routes.root_url }}" class="hover:text-white transition-colors">Home</a></li>
                    <li><a href="/collections/all" class="hover:text-white transition-colors">Shop Online</a></li>
                    <li><a href="/pages/assistance" class="hover:text-white transition-colors">Assistenza</a></li>
                    <li><a href="/pages/club" class="hover:text-white transition-colors">Club Jolly Care</a></li>
                </ul>
            </div>
            <div class="space-y-6">
                <h4 class="font-black uppercase text-[9px] tracking-[0.3em] text-tertiary-fixed opacity-80">Servizi</h4>
                <ul class="space-y-4 font-bold text-xs uppercase tracking-widest text-white/70">
                    <li><a href="/pages/club" class="hover:text-white transition-colors">Jolly Care Hub</a></li>
                    <li><a href="/pages/assistance" class="hover:text-white transition-colors">Ritiro Store</a></li>
                    <li><a href="{{ routes.account_url }}" class="hover:text-white transition-colors">Il mio Account</a></li>
                </ul>
            </div>
            <div class="col-span-2 md:col-span-1 space-y-6">
                <h4 class="font-black uppercase text-[9px] tracking-[0.3em] text-tertiary-fixed opacity-80">Documentazione</h4>
                <ul class="space-y-4 font-bold text-xs uppercase tracking-widest text-white/50">
                    {%- for policy in shop.policies -%}
                        <li><a href="{{ policy.url }}" class="hover:text-white transition-colors">{{ policy.title }}</a></li>
                    {%- endfor -%}
                </ul>
            </div>
        </div>
    </div>

    <!-- BOTTOM BAR -->
    <div class="pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-6">
        <p class="text-[9px] font-black uppercase tracking-[0.2em] text-white/20 italic">
            © {{ 'now' | date: "%Y" }} {{ shop.name }}. Excellence in Pool Management.
        </p>
        <div class="flex gap-3 grayscale opacity-20 hover:opacity-100 hover:grayscale-0 transition-all duration-500">
            {%- for type in shop.enabled_payment_types -%}
                {{ type | payment_type_svg_tag: class: 'h-5 w-auto' }}
            {%- endfor -%}
        </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Jolly Care Footer",
  "settings": [
    {
      "type": "checkbox",
      "id": "newsletter_enable",
      "default": true,
      "label": "Show newsletter"
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Link list",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "richtext",
          "id": "subtext",
          "label": "Text"
        }
      ]
    }
  ]
}
{% endschema %}
