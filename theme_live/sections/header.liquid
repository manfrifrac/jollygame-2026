{%- style -%}
  .header__inline-menu {
    display: flex;
    justify-content: center;
  }
  .list-menu--inline {
    display: flex;
    flex-wrap: wrap;
    list-style: none;
    padding: 0;
    margin: 0;
  }
{%- endstyle -%}

{{ 'component-mega-menu.css' | asset_url | stylesheet_tag }}
<script src="{{ 'details-disclosure.js' | asset_url }}" defer="defer"></script>

<header class="bg-white docked full-width top-0 z-50 sticky shadow-sm border-b border-outline-variant/10" data-debug-marker="JOLLY-DEBUG-123">
  <div class="w-full px-6 py-4 md:px-10 max-w-7xl mx-auto flex flex-col">
    
    <!-- Top Row: Logo, Search, Actions -->
    <div class="flex justify-between items-center w-full gap-4 md:gap-8">
      <!-- Logo -->
      <a href="{{ routes.root_url }}" class="flex items-center group shrink-0">
          <div class="h-12 md:h-16 w-auto flex items-center justify-center transition-transform group-hover:scale-105">
              <img src="{{ 'logo.png' | asset_url }}" alt="{{ shop.name }}" class="h-full w-auto object-contain">
          </div>
      </a>

      <!-- Search Bar (Desktop) -->
      <form action="{{ routes.search_url }}" method="get" role="search" class="hidden md:flex flex-1 max-w-2xl relative">
          <input type="text" name="q" value="{{ search.terms | escape }}" placeholder="Cerca prodotti..." class="w-full bg-surface-container-low border border-outline-variant/20 rounded-full px-6 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all">
          <input type="hidden" name="options[prefix]" value="last">
          <button type="submit" class="absolute right-2 top-1/2 -translate-y-1/2 p-2 text-on-surface-variant hover:text-primary transition-colors flex items-center justify-center">
              <span class="material-symbols-outlined">search</span>
          </button>
      </form>

      <!-- Icons -->
      <div class="flex items-center gap-2 md:gap-4 shrink-0">
          <!-- Mobile Search Icon -->
          <a href="{{ routes.search_url }}" class="md:hidden p-2 text-primary">
              <span class="material-symbols-outlined text-2xl">search</span>
          </a>

          <a href="{{ routes.cart_url }}" class="relative p-2 rounded-full hover:bg-surface-container-low transition-colors" id="cart-icon-bubble">
              <span class="material-symbols-outlined text-primary text-2xl">shopping_cart</span>
              {%- if cart.item_count > 0 -%}
                <span class="absolute top-0 right-0 bg-error text-white text-[9px] font-black rounded-full w-4 h-4 flex items-center justify-center translate-x-1/2 -translate-y-1/2 border-2 border-white">{{ cart.item_count }}</span>
              {%- endif -%}
              <span class="sr-only">{{ 'templates.cart.cart' | t }}</span>
          </a>

        {%- if customer -%}
          <div class="flex items-center gap-4 relative group">

              <div class="p-2 rounded-full hover:bg-surface-container-low transition-colors cursor-pointer">
                   <span class="material-symbols-outlined text-primary text-3xl">account_circle</span>
              </div>

              <div class="absolute right-0 top-full mt-2 w-56 bg-white rounded-[24px] shadow-2xl border border-outline-variant/20 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 overflow-hidden z-[60]">
                  <div class="p-6 border-b border-outline-variant/10 bg-surface-container-low/50">
                      <p class="text-sm font-black text-[#00578E] truncate uppercase tracking-tight">{{ customer.name | default: customer.email }}</p>
                      <p class="text-[10px] text-on-surface-variant font-bold uppercase tracking-widest mt-1">Cliente Registrato</p>
                  </div>
                  <div class="p-2">
                      <a href="https://shopify.com/101135679836/account/profile" class="flex items-center gap-3 w-full text-left p-4 text-[#00578E] font-bold text-xs uppercase tracking-widest hover:bg-surface-container-low rounded-xl transition-colors">
                          <span class="material-symbols-outlined text-[18px]">person</span> Il Mio Profilo
                      </a>
                      <a href="https://shopify.com/101135679836/account/orders?locale=en&region_country=IT" class="flex items-center gap-3 w-full text-left p-4 text-[#00578E] font-bold text-xs uppercase tracking-widest hover:bg-surface-container-low rounded-xl transition-colors mt-1">
                          <span class="material-symbols-outlined text-[18px]">shopping_bag</span> I Miei Ordini
                      </a>
                      <a href="{{ routes.account_logout_url }}" class="flex items-center gap-3 w-full text-left p-4 text-error font-bold text-xs uppercase tracking-widest hover:bg-error-container/30 rounded-xl transition-colors mt-1">
                          <span class="material-symbols-outlined text-[18px]">logout</span> Esci
                      </a>
                  </div>
              </div>
          </div>
        {%- else -%}
          <a href="{{ routes.account_login_url }}" class="p-2 rounded-full hover:bg-surface-container-low transition-colors active:scale-95 duration-200">
            <span class="material-symbols-outlined text-primary text-3xl">account_circle</span>
          </a>
        {%- endif -%}
        
        <button id="MobileMenuToggle" class="block lg:hidden p-2 text-primary active:scale-90 transition-transform">
           <span class="material-symbols-outlined text-3xl">menu</span>
        </button>
      </div>
    </div>
  </div>

  <!-- Bottom Row: Navigation (Desktop Only) -->
  <nav class="hidden lg:block w-full border-t border-outline-variant/5">
      {%- if section.settings.menu != blank -%}
        {% render 'header-mega-menu' %}
      {%- else -%}
        {% render 'shop-navigation' %}
      {%- endif -%}
  </nav>
  
  <div id="MobileMenu" class="hidden absolute top-full left-0 w-full bg-white border-b border-outline-variant/20 shadow-2xl z-[50] overflow-y-auto max-h-[85vh] no-scrollbar">
      <div class="flex flex-col p-6 gap-6">
        {%- for link in linklists['main-menu'].links -%}
          <div class="flex flex-col gap-4 border-b border-outline-variant/10 pb-4 last:border-0">
             {%- liquid
                assign collection_handle = nil
                if link.type == 'collection_link'
                  assign collection_handle = link.object.handle
                  assign collection_obj = link.object
                elsif link.url contains '/collections/'
                  assign collection_handle = link.url | split: '/collections/' | last | split: '?' | first
                  assign collection_obj = collections[collection_handle]
                endif
             -%}
             
             <!-- Mobile Main Category -->
             <div class="flex items-center justify-between group">
                <a href="{{ link.url }}" class="flex items-center gap-4 no-underline flex-1">
                   <div class="w-10 h-10 bg-[#f0f7ff] rounded-xl flex items-center justify-center shrink-0">
                      {%- if collection_obj.image -%}
                         <img src="{{ collection_obj.image | image_url: width: 64 }}" class="w-6 h-6 object-contain" alt="">
                      {%- else -%}
                         <span class="material-symbols-outlined text-primary text-[20px]">category</span>
                      {%- endif -%}
                   </div>
                   <span class="text-sm font-black uppercase tracking-widest text-[#001d33]">{{ link.title }}</span>
                </a>
                {% if link.links != blank %}
                   <button onclick="this.closest('.flex-col').querySelector('.mobile-sublinks').classList.toggle('hidden'); this.querySelector('span').classList.toggle('rotate-180');" class="p-2">
                      <span class="material-symbols-outlined text-primary transition-transform">expand_more</span>
                   </button>
                {% endif %}
             </div>

             <!-- Mobile Sub-links (Crisp & Dark) -->
             {%- if link.links != blank -%}
                <div class="mobile-sublinks hidden flex flex-col gap-3 pl-14 pt-2">
                   {%- for sub_link in link.links -%}
                      <a href="{{ sub_link.url }}" class="text-[13px] font-bold text-[#1b1b1f] no-underline">{{ sub_link.title }}</a>
                      {% if sub_link.links != blank %}
                        <div class="flex flex-col gap-2 pl-4">
                           {%- for grand_link in sub_link.links -%}
                              <a href="{{ grand_link.url }}" class="text-[12px] font-semibold text-[#1b1b1f]/70 no-underline">{{ grand_link.title }}</a>
                           {%- endfor -%}
                        </div>
                      {% endif %}
                   {%- endfor -%}
                </div>
             {%- endif -%}
          </div>
        {%- endfor -%}

        {%- if customer -%}
            <a class="font-black text-[#00578E] text-sm uppercase tracking-widest pt-4 border-t border-outline-variant/20 flex items-center gap-3 px-2" href="{{ routes.account_url }}">
                <span class="material-symbols-outlined">person</span>
                Il Mio Profilo & Piscina
            </a>
        {%- endif -%}
      </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "default": "main-menu",
      "label": "Menu"
    },
    {
      "type": "color_scheme",
      "id": "menu_color_scheme",
      "label": "Menu Color Scheme",
      "default": "scheme-1"
    }
  ]
}
{% endschema %}
