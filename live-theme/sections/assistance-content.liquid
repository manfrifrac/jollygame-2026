{% comment %}
  Assistance Content - Portale Supporto Jolly Care Unificato v2.6
  Integrazione Ticketing Cloud + Branding Jolly Game
  Design: Mobile First, Shield Icon, Jolly Game Blue (#00578E)
{% endcomment %}

<div class="max-w-7xl mx-auto space-y-12 md:space-y-20 py-8 md:py-12 px-4 sm:px-6 lg:px-8 text-primary font-sans">
  
  <!-- 1. HEADER & SOS STATUS (MOBILE FIRST) -->
  <section class="grid grid-cols-1 md:grid-cols-12 gap-6 md:gap-8 items-stretch">
      <div class="md:col-span-8">
          <div class="p-10 md:p-16 rounded-[40px] md:rounded-[48px] bg-[#00578E] text-white overflow-hidden relative min-h-[350px] md:min-h-[380px] flex flex-col justify-between shadow-2xl border border-white/10 group">
              <div class="absolute inset-0 opacity-20 bg-[radial-gradient(circle_at_top_right,_var(--tw-gradient-stops))] from-[#FFDEA5] to-transparent pointer-events-none transition-transform group-hover:scale-110 duration-1000"></div>
              
              <div class="relative z-10">
                  <span class="inline-flex items-center gap-2 bg-white/10 px-4 py-1.5 rounded-full text-[8px] md:text-[9px] font-black mb-6 md:mb-8 tracking-[0.3em] uppercase backdrop-blur-md border border-white/10">
                      <span class="material-symbols-outlined text-[14px] md:text-[16px] text-[#FFDEA5]">shield</span>
                      Jolly Care Support Network
                  </span>
                  <h1 class="text-4xl md:text-7xl font-headline font-extrabold tracking-tighter mb-4 md:mb-6 uppercase italic leading-none">Supporto <br/><span class="text-[#FFDEA5]">Specialistico.</span></h1>
                  <p class="text-white/80 text-base md:text-xl max-w-xl leading-relaxed font-light italic">
                      Diagnostica avanzata e interventi rapidi. Il tuo punto di riferimento per ogni esigenza tecnica sulla piscina.
                  </p>
              </div>

              <div class="relative z-10 mt-8 md:mt-10">
                  <div id="assistance-plan-badge" class="inline-flex items-center gap-4 bg-white/5 p-3 md:p-4 pr-6 md:pr-8 rounded-2xl md:rounded-3xl border border-white/10 backdrop-blur-sm">
                      <div id="plan-icon-box" class="w-10 h-10 md:w-12 md:h-12 rounded-xl md:rounded-2xl bg-white/10 flex items-center justify-center">
                          <span class="material-symbols-outlined text-white text-xl md:text-2xl">hourglass_empty</span>
                      </div>
                      <div>
                          <p id="plan-status-text" class="text-[8px] md:text-[10px] font-black uppercase tracking-widest text-white/60">Verifica...</p>
                          <p id="plan-benefit-text" class="text-[10px] md:text-xs font-bold text-white">Caricamento...</p>
                      </div>
                  </div>
              </div>
              
              <div class="absolute top-0 right-0 w-1/2 h-full opacity-10 pointer-events-none text-white">
                  <span class="material-symbols-outlined text-[250px] md:text-[350px] absolute -right-10 md:-right-20 -top-10 md:-top-20">support_agent</span>
              </div>
          </div>
      </div>
      
      <!-- CARE IDENTITY & SOS WHATSAPP -->
      <div class="md:col-span-4 space-y-6 flex flex-col justify-between">
          <div class="bg-white p-8 md:p-10 rounded-[40px] md:rounded-[48px] border border-outline-variant/15 flex flex-col items-center text-center shadow-sm justify-center group hover:shadow-xl transition-all duration-500">
              <h3 class="font-black text-lg md:text-xl mb-2 text-[#00578E] uppercase tracking-tighter italic">Care Identity</h3>
              <p class="text-[10px] text-on-surface-variant mb-8 font-bold opacity-60 uppercase tracking-widest">Store Access Authorization</p>
              
              {%- if customer -%}
                  <div class="bg-surface-container-low p-6 md:p-8 rounded-3xl shadow-inner mb-6 md:mb-8 relative w-full flex items-center justify-center min-h-[150px] md:min-h-[180px] border border-outline-variant/10 group-hover:border-[#00578E]/20 transition-all">
                      <span class="material-symbols-outlined text-6xl md:text-8xl text-[#00578E] opacity-10 group-hover:opacity-30 transition-all">qr_code_2</span>
                      <div class="absolute inset-0 border-[6px] md:border-[8px] border-white rounded-3xl pointer-events-none shadow-sm"></div>
                  </div>
                  <p class="text-[8px] md:text-[10px] font-mono text-outline font-black tracking-[0.4em] uppercase mb-6 md:mb-8">NODE: {{ customer.id | slice: 0, 12 }}</p>
                  <a href="/pages/club" class="w-full py-4 md:py-5 bg-[#00578E] text-white rounded-2xl font-black text-[9px] md:text-[10px] uppercase tracking-[0.2em] flex items-center justify-center gap-3 hover:scale-105 transition-all shadow-xl">
                      <span class="material-symbols-outlined text-[18px] md:text-[20px]">shield</span>
                      Jolly Care Hub
                  </a>
              {%- else -%}
                  <div class="flex-1 flex flex-col items-center justify-center w-full min-h-[180px] md:min-h-[200px] bg-surface-container-low rounded-[32px] border-2 border-dashed border-outline-variant p-6 md:p-8">
                      <span class="material-symbols-outlined text-4xl text-outline mb-4 md:mb-6 opacity-30">lock</span>
                      <p class="text-[10px] text-on-surface-variant font-black uppercase tracking-widest mb-6 md:mb-8 leading-relaxed">Accedi per sbloccare <br/>la tua Care Identity</p>
                      <a href="{{ routes.account_login_url }}" class="w-full bg-[#00578E] text-white py-3 md:py-4 rounded-xl font-black text-[9px] md:text-[10px] uppercase tracking-widest shadow-lg hover:brightness-110 transition-all text-center">
                          Identificati Ora
                      </a>
                  </div>
              {%- endif -%}
          </div>

          <!-- SOS WHATSAPP EXCLUSIVE -->
          <div class="bg-[#25D366]/10 p-8 rounded-[40px] border-2 border-[#25D366]/30 flex flex-col items-center text-center group hover:bg-[#25D366]/20 transition-all">
              <span class="material-symbols-outlined text-4xl text-[#25D366] mb-4">forum</span>
              <h4 class="text-xl font-black uppercase italic tracking-tighter text-[#00578E]">Linea SOS WhatsApp</h4>
              
              {%- assign role = customer.metafields.custom.livello_abbonamento | downcase -%}
              {%- if role contains 'pro' or role contains 'gold' -%}
                  <p class="text-[9px] font-bold text-emerald-700 uppercase tracking-widest mb-6">Canale VIP Attivo ✅</p>
                  <a href="https://wa.me/393281234567?text=SOS%20Jolly%20Care:%20Ho%20bisogno%20di%20assistenza%20immediata" target="_blank" class="w-full py-4 bg-[#25D366] text-white rounded-2xl font-black text-[10px] uppercase tracking-widest shadow-lg hover:scale-105 transition-all flex items-center justify-center gap-2">
                      Inizia Chat SOS
                  </a>
              {%- else -%}
                  <p class="text-[9px] font-bold text-on-surface-variant opacity-60 uppercase tracking-widest mb-6 leading-relaxed">Disponibile solo per <br/>Membri PRO e GOLD</p>
                  <a href="/products/abbonamento-jolly-care" class="w-full py-4 bg-white border-2 border-[#25D366] text-[#25D366] rounded-2xl font-black text-[10px] uppercase tracking-widest hover:bg-[#25D366] hover:text-white transition-all text-center">
                      Sblocca Linea SOS
                  </a>
              {%- endif -%}
          </div>
      </div>
  </section>

  <!-- 2. FORM SEGNALAZIONE & STORICO -->
  <section id="ticket-section" class="grid grid-cols-1 lg:grid-cols-12 gap-10 md:gap-12 items-start">
      
      <!-- FORM (SINISTRA) -->
      <div class="lg:col-span-7 space-y-8 md:space-y-12">
          <div class="space-y-3 md:space-y-4">
              <h2 class="text-3xl md:text-4xl font-black uppercase italic tracking-tighter text-[#00578E]">Nuova Segnalazione</h2>
              <p class="text-on-surface-variant font-medium text-base md:text-lg italic opacity-70">Richiedi assistenza tecnica specialistica.</p>
          </div>

          {%- if customer -%}
            <div class="bg-white p-8 md:p-10 rounded-[40px] md:rounded-[56px] border border-outline-variant/20 shadow-2xl relative overflow-hidden group">
                <form id="jolly-ticket-form" class="space-y-6 md:space-y-8 relative z-10">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
                        <div class="space-y-3">
                            <label class="block text-[8px] md:text-[10px] font-black text-[#00578E] uppercase tracking-[0.2em]">Ambito Intervento</label>
                            <select id="ticket-type" required class="w-full px-5 py-4 rounded-xl md:rounded-2xl bg-surface-container-low border border-outline-variant font-black uppercase italic text-[10px] h-[60px] md:h-[65px] outline-none focus:border-[#00578E] transition-all">
                                <option value="Guasto Pompa">Pompa / Filtrazione</option>
                                <option value="Acqua Verde">Parametri Acqua / Alghe</option>
                                <option value="Perdita">Perdita / Idraulica</option>
                                <option value="Robot">Robot / Pulitori</option>
                                <option value="Altro">Altro Intervento Tecnico</option>
                            </select>
                        </div>
                        <div class="space-y-3">
                            <label class="block text-[8px] md:text-[10px] font-black text-[#00578E] uppercase tracking-[0.2em]">Priorità Sistema</label>
                            <div id="priority-box" class="h-[60px] md:h-[65px] flex items-center px-5 md:px-6 rounded-xl md:rounded-2xl bg-surface-container text-outline font-black uppercase italic text-[9px] md:text-[10px] tracking-widest border-2 border-dashed border-outline-variant/30">
                                Standard
                            </div>
                        </div>
                    </div>
                    <div class="space-y-3">
                        <label class="block text-[8px] md:text-[10px] font-black text-[#00578E] uppercase tracking-[0.2em]">Descrizione Problema</label>
                        <textarea id="ticket-desc" required rows="4" placeholder="Descrivi qui il problema tecnico..." class="w-full px-5 py-4 md:px-6 md:py-5 rounded-2xl md:rounded-[32px] bg-surface-container-low border border-outline-variant outline-none transition-all focus:border-[#00578E] text-sm"></textarea>
                    </div>
                    <button type="submit" id="submit-btn" class="w-full bg-[#00578E] text-white py-5 md:py-6 rounded-2xl md:rounded-[32px] font-black text-xs uppercase tracking-[0.3em] shadow-xl hover:scale-[1.02] transition-all">Invia al Cloud</button>
                </form>

                <div id="success-msg" class="hidden text-center space-y-6 py-10 md:py-12">
                    <div class="w-16 h-16 md:w-20 md:h-20 bg-emerald-100 text-emerald-600 rounded-full flex items-center justify-center mx-auto"><span class="material-symbols-outlined text-3xl md:text-4xl">check</span></div>
                    <h2 class="text-2xl md:text-3xl font-black uppercase italic text-[#00578E]">Segnalazione Inviata</h2>
                    <p class="text-outline text-xs md:text-sm font-medium italic">Ti contatteremo a breve sui canali certificati Jolly Care.</p>
                    <button onclick="window.location.reload()" class="text-[#00578E] font-black text-[9px] md:text-[10px] uppercase tracking-widest border-b-2 border-[#00578E] pb-1">Nuova Pratica</button>
                </div>
            </div>
          {%- else -%}
            <div class="bg-surface-container-low p-12 md:p-16 rounded-[40px] md:rounded-[56px] text-center border-4 border-dashed border-outline-variant/20">
                <p class="text-outline font-black uppercase tracking-widest text-[10px]">Identificati per inviare segnalazioni</p>
            </div>
          {%- endif -%}
      </div>

      <!-- STORICO (DESTRA) -->
      <div class="lg:col-span-5 space-y-8 md:space-y-12">
          <div class="space-y-3 md:space-y-4">
              <h2 class="text-3xl md:text-4xl font-black uppercase italic tracking-tighter text-[#00578E]">Le mie <span class="text-[#FFDEA5] bg-[#00578E] px-3 py-1 rounded-xl not-italic">Pratiche</span></h2>
              <p class="text-on-surface-variant font-medium text-base md:text-lg italic opacity-70">Stato avanzamento segnalazioni.</p>
          </div>

          <div id="ticket-list" class="space-y-4 max-h-[500px] md:max-h-[600px] overflow-y-auto pr-2 custom-scrollbar">
              <div class="py-12 text-center opacity-30 italic"><p class="text-sm">Nessuna pratica attiva.</p></div>
          </div>
      </div>
  </section>

  <!-- MODALE CHAT TICKET -->
  <div id="ChatModal" class="hidden fixed inset-0 z-[100] flex items-center justify-center p-4 bg-[#001945]/90 backdrop-blur-xl animate-in fade-in duration-300">
      <div class="bg-white w-full max-w-2xl rounded-[40px] shadow-2xl overflow-hidden flex flex-col h-[80vh]">
          <div class="p-6 bg-[#00578E] text-white flex justify-between items-center">
              <div class="flex items-center gap-4">
                  <span class="material-symbols-outlined text-2xl text-[#FFDEA5]">shield</span>
                  <div>
                      <h3 class="font-black uppercase italic tracking-tight leading-none">Dettaglio Pratica</h3>
                      <p id="chat-ticket-id" class="text-[8px] font-bold opacity-60 uppercase tracking-widest mt-1"></p>
                  </div>
              </div>
              <button onclick="closeChat()" class="hover:rotate-90 transition-transform"><span class="material-symbols-outlined">close</span></button>
          </div>
          
          <div id="chat-messages" class="flex-1 overflow-y-auto p-6 space-y-4 bg-surface-container-low flex flex-col">
              <!-- Messaggi caricati dinamicamente -->
          </div>

          <div class="p-6 border-t border-outline-variant/10 bg-white">
              <form id="chat-form" class="flex gap-4">
                  <input type="text" id="chat-input" placeholder="Scrivi un messaggio tecnico..." class="flex-1 px-6 py-4 rounded-2xl bg-surface-container-low border border-outline-variant outline-none focus:border-[#00578E] text-sm">
                  <button type="submit" class="bg-[#00578E] text-white px-8 rounded-2xl font-black text-[10px] uppercase tracking-widest hover:scale-105 transition-all">Invia</button>
              </form>
          </div>
      </div>
  </div>
</div>

<script>
  (function() {
    const API_URL = "https://trains-preventing-programs-vic.trycloudflare.com/public";
    const CRM_URL = "https://trains-preventing-programs-vic.trycloudflare.com/api";
    const cid = "{{ customer.id }}";
    if (!cid) return;

    let activeTicketId = null;
    let chatInterval = null;

    window.openChat = (ticketId) => {
        activeTicketId = ticketId;
        document.getElementById('chat-ticket-id').innerText = "ID: " + ticketId.split('/').pop();
        document.getElementById('ChatModal').classList.remove('hidden');
        loadMessages();
        if(chatInterval) clearInterval(chatInterval);
        chatInterval = setInterval(loadMessages, 5000);
    };

    window.closeChat = () => {
        document.getElementById('ChatModal').classList.add('hidden');
        clearInterval(chatInterval);
        activeTicketId = null;
    };

    const loadMessages = () => {
        if(!activeTicketId) return;
        fetch(`${CRM_URL}/messages?ticketId=${encodeURIComponent(activeTicketId)}`)
          .then(res => res.json())
          .then(msgs => {
              const box = document.getElementById('chat-messages');
              box.innerHTML = msgs.map(m => `
                  <div class="max-w-[85%] p-4 rounded-2xl shadow-sm ${m.autore?.value === 'Staff' ? 'bg-[#00578E] text-white self-start' : 'bg-white border border-outline-variant/20 self-end'}">
                      <p class="text-[7px] font-black uppercase tracking-widest mb-1 ${m.autore?.value === 'Staff' ? 'text-[#FFDEA5]' : 'text-[#00578E]'}">${m.autore?.value}</p>
                      <p class="text-sm font-medium leading-relaxed">${m.messaggio?.value}</p>
                      <p class="text-[6px] opacity-40 mt-2 text-right">${new Date(m.timestamp?.value).toLocaleTimeString()}</p>
                  </div>
              `).join('');
              box.scrollTop = box.scrollHeight;
          });
    };

    document.getElementById('chat-form').addEventListener('submit', (e) => {
        e.preventDefault();
        const input = document.getElementById('chat-input');
        if(!input.value.trim()) return;

        fetch(`${CRM_URL}/messages`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ ticketId: activeTicketId, autore: 'Cliente', messaggio: input.value })
        }).then(() => {
            input.value = '';
            loadMessages();
        });
    });

    const planIconBox = document.getElementById('plan-icon-box');
    const planStatusText = document.getElementById('plan-status-text');
    const planBenefitText = document.getElementById('plan-benefit-text');
    const priorityBox = document.getElementById('priority-box');
    const cleanId = cid.split('/').pop();
    const GID = "gid://shopify/Customer/" + cleanId;

    let userRole = "Base";

    fetch(`${API_URL}/customer-data/${cleanId}?t=${Date.now()}`)
      .then(res => res.json())
      .then(data => {
        userRole = data.role || "Base";
        const isPremium = userRole.toLowerCase().includes('gold') || userRole.toLowerCase().includes('pro');
        
        if(isPremium) {
          planIconBox.className = "w-10 h-10 md:w-12 md:h-12 rounded-xl md:rounded-2xl bg-emerald-500/20 flex items-center justify-center";
          planIconBox.innerHTML = '<span class="material-symbols-outlined text-emerald-400 text-xl md:text-2xl">workspace_premium</span>';
          planStatusText.innerText = `Membro ${userRole}`;
          planBenefitText.innerText = userRole.includes('Gold') ? "Priorità SOS VIP" : "Supporto PRO Attivo";
          
          priorityBox.innerText = userRole.includes('Gold') ? "ALTA (VIP SOS)" : "ALTA (PRO)";
          priorityBox.className = "h-[60px] md:h-[65px] flex items-center px-5 md:px-6 rounded-xl md:rounded-2xl bg-emerald-600 text-white font-black uppercase italic text-[9px] md:text-[10px] tracking-widest border-none animate-pulse";
        } else {
          planIconBox.className = "w-10 h-10 md:w-12 md:h-12 rounded-xl md:rounded-2xl bg-amber-500/20 flex items-center justify-center";
          planIconBox.innerHTML = '<span class="material-symbols-outlined text-amber-400 text-xl md:text-2xl">info</span>';
          planStatusText.innerText = "Membro Base";
          planBenefitText.innerText = "Ticket Standard - Uscita €100";
        }
      });

    const loadTickets = () => {
        fetch(`${CRM_URL}/tickets`)
          .then(res => res.json())
          .then(tickets => {
              const list = document.getElementById('ticket-list');
              const myTickets = tickets.filter(t => t.customer?.reference?.id === GID);
              if(myTickets.length > 0) {
                  list.innerHTML = myTickets.map(t => `
                      <div class="bg-white p-5 md:p-6 rounded-2xl md:rounded-[28px] border border-outline-variant/15 flex flex-col gap-3 md:gap-4 group hover:border-[#00578E] transition-all shadow-sm">
                          <div class="flex justify-between items-start">
                              <span class="px-2 md:px-3 py-1 bg-[#00578E]/5 text-[#00578E] rounded-lg font-black text-[7px] md:text-[8px] uppercase tracking-widest">${t.type?.value || 'Segnalazione'}</span>
                              <span class="px-2 md:px-3 py-1 ${t.status?.value === 'Open' ? 'bg-amber-100 text-amber-700' : 'bg-emerald-100 text-emerald-700'} rounded-lg font-black text-[7px] md:text-[8px] uppercase tracking-widest">${t.status?.value || 'In lavorazione'}</span>
                          </div>
                          <p class="text-xs font-medium text-outline italic line-clamp-2">${t.description?.value || ''}</p>
                          <div class="pt-3 md:pt-4 border-t border-outline-variant/10 flex justify-between items-center">
                              <p class="text-[7px] md:text-[8px] font-bold text-outline/40 uppercase tracking-widest">${new Date(t.updatedAt).toLocaleDateString()}</p>
                              <button onclick="openChat('${t.id}')" class="text-[7px] md:text-[8px] font-black uppercase tracking-[0.2em] text-[#00578E] hover:text-tertiary-fixed transition-colors">Dettaglio Pratica →</button>
                          </div>
                      </div>
                  `).join('');
              }
          });
    };
    loadTickets();

    const form = document.getElementById('jolly-ticket-form');
    if(form) {
      form.addEventListener('submit', function(e) {
        e.preventDefault();
        const btn = document.getElementById('submit-btn');
        btn.disabled = true;
        btn.innerText = "ATTESA...";

        fetch(`${API_URL}/create-ticket`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            customerId: GID,
            type: document.getElementById('ticket-type').value,
            description: document.getElementById('ticket-desc').value,
            priority: (userRole.toLowerCase().includes('gold') || userRole.toLowerCase().includes('pro')) ? "High" : "Normal"
          })
        })
        .then(res => res.json())
        .then(res => {
          if(res.success) {
            form.classList.add('hidden');
            document.getElementById('success-msg').classList.remove('hidden');
            loadTickets();
          }
        });
      });
    }
  })();
</script>

{% schema %}
{ "name": "Supporto Assistenza" }
{% endschema %}

