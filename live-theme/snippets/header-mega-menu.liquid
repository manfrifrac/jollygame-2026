{% comment %}
  Renders a premium megamenu for the header using Tailwind CSS.
  JollyGame 2026 - Premium Glassmorphism Overhaul (Refined for Readability)
{% endcomment %}

<nav class="header__inline-menu">
  <ul class="list-menu list-menu--inline flex justify-center gap-6" role="list">
    {%- for link in linklists['main-menu'].links -%}
      <li class="group/main">
        {%- if link.links != blank -%}
          <header-menu>
            <details id="Details-HeaderMenu-{{ forloop.index }}" class="mega-menu">
              <summary
                id="HeaderMenu-{{ link.handle }}"
                class="header__menu-item list-menu__item link focus-inset flex items-center gap-2 px-2 py-6 text-[13px] font-black uppercase tracking-[0.1em] text-[#003d66] hover:text-primary transition-colors cursor-pointer"
              >
                <span {%- if link.child_active %} class="header__active-menu-item" {% endif %}>
                  {{- link.title | escape -}}
                </span>
                <span class="material-symbols-outlined text-[16px] opacity-40 transition-transform group-open:rotate-180">expand_more</span>
              </summary>
              
              <div
                id="MegaMenu-Content-{{ forloop.index }}"
                class="mega-menu__content absolute top-full left-0 w-full bg-white backdrop-blur-md border-t border-[#00578E]/10 shadow-[0_30px_60px_-15px_rgba(0,0,0,0.2)]"
                tabindex="-1"
              >
                <div class="max-w-[1800px] mx-auto flex items-stretch min-h-[400px]">

                  <!-- Left Sidebar: 2-Column Vertical Categories (Maximum Readability) -->
                  <div class="w-[600px] shrink-0 border-r border-[#00578E]/10 px-10 py-12 bg-white shadow-[10px_0_30px_-5px_rgba(0,0,0,0.02)]">
                    <div class="grid grid-cols-2 gap-x-10 gap-y-10 overflow-y-auto max-h-[75vh] no-scrollbar">
                      {%- for childlink in link.links -%}
                        <div class="flex flex-col gap-4">
                          {%- liquid
                             assign collection_handle = nil
                             if childlink.type == 'collection_link'
                               assign collection_handle = childlink.object.handle
                               assign collection_obj = childlink.object
                             elsif childlink.url contains '/collections/'
                               assign collection_handle = childlink.url | split: '/collections/' | last | split: '?' | first
                               assign collection_obj = collections[collection_handle]
                             endif
                          -%}

                          <!-- Category Header with Icon -->
                          <a
                            id="HeaderMenu-{{ link.handle }}-{{ childlink.handle }}"
                            href="{{ childlink.url }}"
                            class="flex items-center gap-3 group/item no-underline"
                          >
                            <div class="w-10 h-10 bg-[#f0f7ff] rounded-[14px] border border-[#00578E]/15 flex items-center justify-center shadow-sm group-hover/item:scale-110 group-hover/item:bg-white transition-all duration-500 shrink-0">
                              {%- if collection_obj.image -%}
                                <img
                                  src="{{ collection_obj.image | image_url: width: 80 }}"
                                  alt="{{ collection_obj.title | escape }}"
                                  class="w-7 h-7 object-contain"
                                  loading="lazy"
                                >
                              {%- else -%}
                                 <span class="material-symbols-outlined text-primary/40 text-[20px]">category</span>
                              {%- endif -%}
                            </div>
                            <span class="text-[12px] font-black uppercase tracking-widest text-[#001d33] group-hover/item:text-primary transition-colors leading-tight">
                              {{ childlink.title | escape }}
                            </span>
                          </a>

                          <!-- Sub-links (High Contrast) -->
                          {%- if childlink.links != blank -%}
                            <ul class="flex flex-col gap-2 ml-[3.25rem]" role="list">
                              {%- for grandchildlink in childlink.links -%}
                                <li>
                                  <a
                                    id="HeaderMenu-{{ link.handle }}-{{ childlink.handle }}-{{ grandchildlink.handle }}"
                                    href="{{ grandchildlink.url }}"
                                    class="text-[13px] font-bold text-[#1b1b1f] hover:text-primary hover:translate-x-1 inline-block transition-all duration-300 no-underline leading-none"
                                  >
                                    {{ grandchildlink.title | escape }}
                                  </a>
                                </li>
                              {%- endfor -%}
                            </ul>
                          {%- endif -%}
                        </div>
                      {%- endfor -%}
                    </div>
                  </div>

                  <!-- Right Area: Featured Product SLIDER (Matched Height) -->
                  {%- liquid
                    assign parent_collection = nil
                    if link.type == 'collection_link'
                      assign parent_collection = link.object
                    elsif link.url contains '/collections/'
                      assign p_handle = link.url | split: '/collections/' | last | split: '?' | first
                      assign parent_collection = collections[p_handle]
                    endif
                    
                    assign featured_list = parent_collection.metafields.custom.featured_products_list.value
                    if featured_list == blank
                       assign featured_list = parent_collection.products | limit: 6
                    endif
                  -%}

                  <div class="flex-1 bg-white p-10 flex flex-col justify-center overflow-hidden border-l border-[#00578E]/5">
                    <div class="flex items-center justify-between mb-6">
                       <h3 class="text-xs font-black uppercase tracking-[0.2em] text-[#00578E]">I nostri consigliati</h3>
                       <div class="flex gap-2 items-center">
                          <span class="text-[9px] font-bold text-[#1b1b1f]/60 italic">Scorri</span>
                          <span class="material-symbols-outlined text-[16px] animate-bounce-x text-primary">arrow_forward</span>
                       </div>
                    </div>
                    
                    <div class="flex gap-6 overflow-x-auto snap-x snap-mandatory no-scrollbar pb-4">
                      {%- for prod in featured_list -%}
                        <div class="w-[260px] shrink-0 snap-center">
                          <div class="relative group/card bg-white rounded-[32px] p-6 border border-[#00578E]/10 hover:shadow-[0_40px_80px_-20px_rgba(0,87,142,0.15)] hover:-translate-y-2 transition-all duration-700 h-full flex flex-col">
                            <a href="{{ prod.url }}" class="flex flex-col gap-5 no-underline flex-1">
                              <div class="aspect-square bg-[#f0f7ff]/20 rounded-[24px] overflow-hidden flex items-center justify-center p-4">
                                <img src="{{ prod.featured_image | image_url: width: 500 }}" alt="{{ prod.title | escape }}" class="w-full h-full object-contain group-hover/card:scale-110 transition-transform duration-1000" loading="lazy">
                              </div>
                              <div class="flex flex-col gap-2.5 flex-1">
                                <h3 class="text-[14px] font-black text-[#00578E] leading-tight tracking-tight uppercase">{{ prod.title | escape }}</h3>
                                <p class="text-xl font-black text-primary">{{ prod.price | money }}</p>
                                <div class="mt-auto pt-2 flex items-center justify-between">
                                  <span class="text-[8px] font-black uppercase tracking-widest text-[#00578E]/30 italic">Top Quality</span>
                                  <div class="w-8 h-8 rounded-full bg-primary text-white flex items-center justify-center group-hover/card:w-16 group-hover/card:rounded-lg transition-all duration-500 overflow-hidden shadow-lg shadow-primary/20">
                                     <div class="flex items-center gap-2 px-3 whitespace-nowrap">
                                        <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
                                     </div>
                                  </div>
                                </div>
                              </div>
                            </a>
                          </div>
                        </div>
                      {%- endfor -%}
                    </div>
                  </div>
                </div>
              </div>
            </details>
          </header-menu>
        {%- else -%}
          <a
            id="HeaderMenu-{{ link.handle }}"
            href="{{ link.url }}"
            class="header__menu-item list-menu__item link focus-inset px-4 py-6 text-[13px] font-black uppercase tracking-[0.1em] text-[#003d66] hover:text-primary"
          >
            <span {%- if link.current %} class="header__active-menu-item underline decoration-2 underline-offset-8" {% endif %}>
              {{- link.title | escape -}}
            </span>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </ul>
</nav>

<style>
  .mega-menu__content {
    opacity: 0;
    visibility: hidden;
    transform: translateY(15px);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    display: block !important;
  }
  
  details[open] .mega-menu__content {
    opacity: 1 !important;
    visibility: visible !important;
    transform: translateY(0) !important;
  }
  
  details summary::-webkit-details-marker { display: none; }
  details summary { list-style: none; }
  
  .header__active-menu-item {
    color: var(--color-primary) !important;
    position: relative;
  }
  .header__active-menu-item::after {
    content: '';
    position: absolute;
    bottom: -8px;
    left: 0;
    width: 100%;
    height: 3px;
    background: #0268a6;
    border-radius: 10px;
  }
</style>

